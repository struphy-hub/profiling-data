---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Struphy Profiling Dashboard" description="Professional overview of profiling cases and generated plots.">
  <section class="hero">
    <h1>Struphy profiling dashboard</h1>
    <p>
      Overview of available profiling cases. Open a case to inspect detailed metadata and view the generated
      durations/speedup plots.
    </p>
  </section>

  <section class="card" style="margin-top: 1rem;">
    <h2>Cases</h2>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>Case title</th>
            <th>Description</th>
            <th>Runs</th>
            <th>Ranks</th>
            <th>Open</th>
          </tr>
        </thead>
        <tbody id="home-cases-table-body"></tbody>
      </table>
    </div>
  </section>
</BaseLayout>

<script>
  const rawBaseUrl = import.meta.env.BASE_URL;
  const baseUrl = rawBaseUrl.endsWith("/") ? rawBaseUrl : `${rawBaseUrl}/`;
  const tableBody = document.getElementById("home-cases-table-body");

  const esc = (value) =>
    String(value ?? "")
      .replaceAll("&", "&amp;")
      .replaceAll("<", "&lt;")
      .replaceAll(">", "&gt;")
      .replaceAll('"', "&quot;");

  const basename = (path) => {
    if (!path) return "";
    const parts = String(path).split("/");
    return parts[parts.length - 1];
  };

  const getCaseTitle = (entry) => {
    if (Object.hasOwn(entry, "title")) return String(entry.title ?? "");
    return String(entry.label ?? "Unnamed case").replaceAll("-", " ");
  };

  const getCaseDescription = (entry) => {
    if (Object.hasOwn(entry, "description")) return String(entry.description ?? "");
    const source = basename(entry.file_path);
    if (source) return `Source file: ${source}`;
    return "Profiling case from generated statistics.";
  };

  const getCaseFolder = (entry) => {
    const path = String(entry?.file_path ?? "");
    if (!path) return "unknown-case";
    const parts = path.split("/").filter(Boolean);
    if (parts.length < 2) return parts[0] || "unknown-case";
    return parts[parts.length - 2];
  };

  const shouldClampDescription = (value) => {
    const text = String(value ?? "");
    return text.length > 180 || text.includes("\n");
  };

  const bindDescriptionToggles = () => {
    tableBody.querySelectorAll(".desc-toggle").forEach((button) => {
      button.addEventListener("click", () => {
        const description = button.parentElement?.querySelector(".case-description");
        if (!description) return;

        const isExpanded = description.classList.toggle("case-description--expanded");
        button.setAttribute("aria-expanded", isExpanded ? "true" : "false");
        button.textContent = isExpanded ? "Collapse" : "Expand";
      });
    });
  };

  const render = async () => {
    try {
      const res = await fetch(`${baseUrl}figures/region_statistics.json`);
      if (!res.ok) throw new Error(`HTTP ${res.status}`);
      const data = await res.json();
      const files = Array.isArray(data.files) ? data.files.slice() : [];
      files.sort((a, b) => (a.num_ranks ?? Number.MAX_SAFE_INTEGER) - (b.num_ranks ?? Number.MAX_SAFE_INTEGER));

      const groupedCases = new Map();
      files.forEach((entry) => {
        const folder = getCaseFolder(entry);
        const current = groupedCases.get(folder) ?? {
          folder,
          title: getCaseTitle(entry),
          description: getCaseDescription(entry),
          labels: [],
          ranks: new Set(),
        };
        if (entry.label) current.labels.push(entry.label);
        if (Number.isFinite(entry.num_ranks)) current.ranks.add(entry.num_ranks);
        groupedCases.set(folder, current);
      });

      const groupedList = Array.from(groupedCases.values()).sort((a, b) => a.title.localeCompare(b.title));
      if (!groupedList.length) {
        tableBody.innerHTML = '<tr><td colspan="5" class="muted">No cases found in region_statistics.json.</td></tr>';
        return;
      }

      tableBody.innerHTML = groupedList
        .map((group) => {
          const caseId = encodeURIComponent(group.folder);
          const ranks = Array.from(group.ranks).sort((a, b) => a - b);
          const rankSummary = ranks.length ? ranks.join(", ") : "-";
          const clampDescription = shouldClampDescription(group.description);
          const descriptionClass = clampDescription
            ? "case-description case-description--clamped"
            : "case-description";
          return `
            <tr>
              <td><strong>${esc(group.title)}</strong></td>
              <td class="muted">
                <div class="${descriptionClass}">${esc(group.description)}</div>
                ${clampDescription ? '<button type="button" class="desc-toggle" aria-expanded="false">Expand</button>' : ""}
              </td>
              <td>${group.labels.length}</td>
              <td>${esc(rankSummary)}</td>
              <td><a href="${baseUrl}figures?case=${caseId}#cases">View details</a></td>
            </tr>
          `;
        })
        .join("");
      bindDescriptionToggles();
    } catch (error) {
      tableBody.innerHTML = `<tr><td colspan="5" class="muted">Could not load case table: ${esc(error)}</td></tr>`;
    }
  };

  render();
</script>
