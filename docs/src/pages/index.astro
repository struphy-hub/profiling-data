---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Struphy Profiling Dashboard" description="Professional overview of profiling cases and generated plots.">
  <section class="hero">
    <h1>Struphy profiling dashboard</h1>
    <p>
      Overview of available profiling cases. Open a case to see every instance it has been run (one per submission),
      then drill into an instance to inspect its runs, metadata, and generated durations/speedup plots.
    </p>
  </section>

  <section class="card" style="margin-top: 1rem;">
    <h2>Cases</h2>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>Case title</th>
            <th>Description</th>
            <th>Physics problem</th>
            <th>Struphy model used</th>
            <th>Instances</th>
            <th>Latest run</th>
            <th>Open</th>
          </tr>
        </thead>
        <tbody id="home-cases-table-body"></tbody>
      </table>
    </div>
  </section>
</BaseLayout>

<script>
  import { groupCases, groupKeyForCase, groupLabelForCase } from "../lib/cases.js";

  const rawBaseUrl = import.meta.env.BASE_URL;
  const baseUrl = rawBaseUrl.endsWith("/") ? rawBaseUrl : `${rawBaseUrl}/`;
  const tableBody = document.getElementById("home-cases-table-body");

  const esc = (value) =>
    String(value ?? "")
      .replaceAll("&", "&amp;")
      .replaceAll("<", "&lt;")
      .replaceAll(">", "&gt;")
      .replaceAll('"', "&quot;");

  const formatDatetime = (value) => {
    const text = String(value ?? "");
    if (!text) return "-";
    const parsed = new Date(text);
    if (Number.isNaN(parsed.getTime())) return text;
    return parsed.toLocaleString();
  };

  const shouldClampDescription = (value) => {
    const text = String(value ?? "");
    return text.length > 180 || text.includes("\n");
  };

  const bindDescriptionToggles = () => {
    tableBody.querySelectorAll(".desc-toggle").forEach((button) => {
      button.addEventListener("click", () => {
        const description = button.parentElement?.querySelector(".case-description");
        if (!description) return;

        const isExpanded = description.classList.toggle("case-description--expanded");
        button.setAttribute("aria-expanded", isExpanded ? "true" : "false");
        button.textContent = isExpanded ? "Collapse" : "Expand";
      });
    });
  };

  // Joins the distinct, non-empty values for a field across all instances of
  // a case, since e.g. the struphy model or physics problem is expected to
  // be constant per case but is technically stored per instance.
  const distinctValues = (entries, getter) => {
    const values = [];
    for (const entry of entries) {
      const value = String(getter(entry) ?? "").trim();
      if (value && !values.includes(value)) values.push(value);
    }
    return values;
  };

  const render = async () => {
    try {
      const res = await fetch(`${baseUrl}figures/region_statistics.json`);
      if (!res.ok) throw new Error(`HTTP ${res.status}`);
      const data = await res.json();
      const cases = Array.isArray(data.cases) ? data.cases.slice() : [];
      if (!cases.length) {
        tableBody.innerHTML = '<tr><td colspan="7" class="muted">No cases found in region_statistics.json.</td></tr>';
        return;
      }

      const groups = [...groupCases(cases).entries()].map(([groupKey, entries]) => {
        const sorted = entries
          .slice()
          .sort((a, b) => String(b.datetime_utc ?? "").localeCompare(String(a.datetime_utc ?? "")));
        return { groupKey, entries: sorted, latest: sorted[0] };
      });
      groups.sort((a, b) => String(b.latest?.datetime_utc ?? "").localeCompare(String(a.latest?.datetime_utc ?? "")));

      tableBody.innerHTML = groups
        .map(({ groupKey, entries, latest }) => {
          const description = String(latest?.description ?? "");
          const clampDescription = shouldClampDescription(description);
          const descriptionClass = clampDescription
            ? "case-description case-description--clamped"
            : "case-description";
          const physicsProblems = distinctValues(entries, (entry) => entry.physics_problem);
          const models = distinctValues(entries, (entry) => entry.struphy_model_used);
          return `
            <tr>
              <td><strong>${esc(groupLabelForCase(latest))}</strong></td>
              <td class="muted">
                <div class="${descriptionClass}">${esc(description || "-")}</div>
                ${clampDescription ? '<button type="button" class="desc-toggle" aria-expanded="false">Expand</button>' : ""}
              </td>
              <td>${esc(physicsProblems.join(", ") || "-")}</td>
              <td>${esc(models.join(", ") || "-")}</td>
              <td>${entries.length}</td>
              <td>${esc(formatDatetime(latest?.datetime_utc))}</td>
              <td><a href="${baseUrl}instances?group=${encodeURIComponent(groupKey)}">View instances</a></td>
            </tr>
          `;
        })
        .join("");
      bindDescriptionToggles();
    } catch (error) {
      tableBody.innerHTML = `<tr><td colspan="7" class="muted">Could not load case table: ${esc(error)}</td></tr>`;
    }
  };

  render();
</script>
