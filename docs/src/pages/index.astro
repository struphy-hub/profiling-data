---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Struphy Profiling Dashboard" description="Professional overview of profiling cases and generated plots.">
  <section class="hero">
    <h1>Struphy profiling dashboard</h1>
    <p>
      Overview of available profiling cases. Open a case to inspect detailed metadata and view the generated
      durations/speedup plots.
    </p>
  </section>

  <section class="card" style="margin-top: 1rem;">
    <h2>Cases</h2>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>Datetime</th>
            <th>Case title</th>
            <th>Description</th>
            <th>Struphy model used</th>
            <th>Physics problem</th>
            <th>Cluster name</th>
            <th>Ranks</th>
            <th>Open</th>
          </tr>
        </thead>
        <tbody id="home-cases-table-body"></tbody>
      </table>
    </div>
  </section>
</BaseLayout>

<script>
  const rawBaseUrl = import.meta.env.BASE_URL;
  const baseUrl = rawBaseUrl.endsWith("/") ? rawBaseUrl : `${rawBaseUrl}/`;
  const tableBody = document.getElementById("home-cases-table-body");

  const esc = (value) =>
    String(value ?? "")
      .replaceAll("&", "&amp;")
      .replaceAll("<", "&lt;")
      .replaceAll(">", "&gt;")
      .replaceAll('"', "&quot;");

  const formatDatetime = (value) => {
    const text = String(value ?? "");
    if (!text) return "-";
    const parsed = new Date(text);
    if (Number.isNaN(parsed.getTime())) return text;
    return parsed.toLocaleString();
  };

  const shouldClampDescription = (value) => {
    const text = String(value ?? "");
    return text.length > 180 || text.includes("\n");
  };

  const bindDescriptionToggles = () => {
    tableBody.querySelectorAll(".desc-toggle").forEach((button) => {
      button.addEventListener("click", () => {
        const description = button.parentElement?.querySelector(".case-description");
        if (!description) return;

        const isExpanded = description.classList.toggle("case-description--expanded");
        button.setAttribute("aria-expanded", isExpanded ? "true" : "false");
        button.textContent = isExpanded ? "Collapse" : "Expand";
      });
    });
  };

  const render = async () => {
    try {
      const res = await fetch(`${baseUrl}figures/region_statistics.json`);
      if (!res.ok) throw new Error(`HTTP ${res.status}`);
      const data = await res.json();
      const cases = Array.isArray(data.cases) ? data.cases.slice() : [];
      cases.sort((a, b) => String(b.datetime_utc ?? "").localeCompare(String(a.datetime_utc ?? "")));
      if (!cases.length) {
        tableBody.innerHTML = '<tr><td colspan="8" class="muted">No cases found in region_statistics.json.</td></tr>';
        return;
      }

      tableBody.innerHTML = cases
        .map((entry) => {
          const caseId = encodeURIComponent(entry.id ?? "");
          const ranks = Array.isArray(entry.ranks) ? entry.ranks.slice().sort((a, b) => a - b) : [];
          const rankSummary = ranks.length ? ranks.join(", ") : "-";
          const description = String(entry.description ?? "");
          const clampDescription = shouldClampDescription(description);
          const descriptionClass = clampDescription
            ? "case-description case-description--clamped"
            : "case-description";
          return `
            <tr>
              <td>${esc(formatDatetime(entry.datetime_utc))}</td>
              <td><strong>${esc(entry.title ?? "-")}</strong></td>
              <td class="muted">
                <div class="${descriptionClass}">${esc(description || "-")}</div>
                ${clampDescription ? '<button type="button" class="desc-toggle" aria-expanded="false">Expand</button>' : ""}
              </td>
              <td>${esc(entry.struphy_model_used ?? "-")}</td>
              <td>${esc(entry.physics_problem ?? "-")}</td>
              <td>${esc(entry.cluster_name ?? "-")}</td>
              <td>${esc(rankSummary)}</td>
              <td><a href="${baseUrl}figures?case=${caseId}#cases">View details</a></td>
            </tr>
          `;
        })
        .join("");
      bindDescriptionToggles();
    } catch (error) {
      tableBody.innerHTML = `<tr><td colspan="8" class="muted">Could not load case table: ${esc(error)}</td></tr>`;
    }
  };

  render();
</script>
