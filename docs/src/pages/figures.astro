---
import BaseLayout from "../layouts/BaseLayout.astro";
const baseUrl = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
---

<BaseLayout title="Profiling Figures" description="Durations and speedup plots plus case metadata explorer.">
  <section class="hero">
    <h1>Profiling figures</h1>
    <p>Matplotlib plots from the latest profiling run, with case metadata details below.</p>
  </section>

  <section class="grid cards-2">
    <article class="card figure-tile">
      <h3 id="durations-title">Durations</h3>
      <a id="durations-link" href="#" target="_blank" rel="noreferrer">
        <img id="durations-image" src="" alt="Durations plot" loading="lazy" />
      </a>
    </article>
    <article class="card figure-tile">
      <h3 id="speedup-title">Speedup</h3>
      <a id="speedup-link" href="#" target="_blank" rel="noreferrer">
        <img id="speedup-image" src="" alt="Speedup plot" loading="lazy" />
      </a>
    </article>
  </section>

  <section id="cases" class="card" style="margin-top: 1rem;">
    <h2>Case metadata explorer</h2>
    <p class="muted">Select a run to inspect rank-specific region-level timing statistics.</p>
    <div id="case-meta-panel" class="card" style="margin-bottom: 1rem;"></div>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>Run label</th>
            <th>Ranks</th>
            <th>Regions</th>
            <th>Open</th>
          </tr>
        </thead>
        <tbody id="cases-table-body"></tbody>
      </table>
    </div>
    <div id="case-panel" class="card" style="margin-top: 1rem;"></div>
  </section>
</BaseLayout>

<script>
  const rawBaseUrl = import.meta.env.BASE_URL;
  const baseUrl = rawBaseUrl.endsWith("/") ? rawBaseUrl : `${rawBaseUrl}/`;
  const casesTableBody = document.getElementById("cases-table-body");
  const casePanel = document.getElementById("case-panel");
  const caseMetaPanel = document.getElementById("case-meta-panel");
  const durationsTitle = document.getElementById("durations-title");
  const speedupTitle = document.getElementById("speedup-title");
  const durationsLink = document.getElementById("durations-link");
  const speedupLink = document.getElementById("speedup-link");
  const durationsImage = document.getElementById("durations-image");
  const speedupImage = document.getElementById("speedup-image");

  const fmt = (value) => {
    if (typeof value !== "number" || Number.isNaN(value)) return "-";
    if (Math.abs(value) >= 1) return value.toFixed(4);
    return value.toExponential(3);
  };

  const esc = (value) =>
    String(value ?? "")
      .replaceAll("&", "&amp;")
      .replaceAll("<", "&lt;")
      .replaceAll(">", "&gt;")
      .replaceAll('"', "&quot;");

  const fmtValue = (value) => {
    if (value === null || value === undefined || value === "") return "-";
    if (typeof value === "object") return esc(JSON.stringify(value));
    return esc(String(value));
  };

  const formatDatetime = (value) => {
    const text = String(value ?? "");
    if (!text) return "-";
    const parsed = new Date(text);
    if (Number.isNaN(parsed.getTime())) return text;
    return parsed.toLocaleString();
  };

  const renderCase = (entry, regions) => {
    const stats = entry.region_statistics || {};
    const displayRegions = regions.length ? regions : Object.keys(stats);
    const rows = displayRegions
      .map((region) => {
        const s = stats[region];
        if (!s) return "";
        return `
          <tr>
            <td>${esc(region)}</td>
            <td>${s.count ?? "-"}</td>
            <td>${fmt(s.average_duration_seconds)}</td>
            <td>${fmt(s.min_duration_seconds)}</td>
            <td>${fmt(s.max_duration_seconds)}</td>
            <td>${fmt(s.total_duration_seconds)}</td>
          </tr>
        `;
      })
      .join("");

    casePanel.innerHTML = `
      <h3 style="margin-top:0;">${esc(entry.label ?? "Unnamed run")}</h3>
      <p class="muted" style="margin-top:0;">
        <strong>Ranks:</strong> ${entry.num_ranks ?? "-"}
      </p>
      <div style="overflow-x:auto;">
        <table>
          <thead>
            <tr>
              <th>Region</th>
              <th>Count</th>
              <th>Avg (s)</th>
              <th>Min (s)</th>
              <th>Max (s)</th>
              <th>Total (s)</th>
            </tr>
          </thead>
          <tbody>${rows || '<tr><td colspan="6">No region statistics available.</td></tr>'}</tbody>
        </table>
      </div>
    `;
  };

  const renderPlots = (selectedCase) => {
    const caseId = selectedCase?.id ?? "unknown";
    const durationsPath = selectedCase?.plots?.durations;
    const speedupPath = selectedCase?.plots?.speedup;
    const durationsUrl = durationsPath ? `${baseUrl}figures/${durationsPath}` : "";
    const speedupUrl = speedupPath ? `${baseUrl}figures/${speedupPath}` : "";

    durationsTitle.textContent = `Durations (${caseId})`;
    speedupTitle.textContent = `Speedup (${caseId})`;
    durationsLink.href = durationsUrl || "#";
    speedupLink.href = speedupUrl || "#";
    durationsImage.src = durationsUrl;
    speedupImage.src = speedupUrl;
  };

  const renderCaseMetadata = (selectedCase) => {
    const metadata = selectedCase?.case_metadata ?? {};
    caseMetaPanel.innerHTML = `
      <h3 style="margin-top:0;">${esc(selectedCase?.title ?? "Case metadata")}</h3>
      <div class="metadata-grid">
        <div><strong>Datetime:</strong> ${esc(formatDatetime(selectedCase?.datetime_utc ?? metadata.datetime_utc))}</div>
        <div><strong>Model:</strong> ${fmtValue(selectedCase?.struphy_model_used ?? metadata.struphy_model_used)}</div>
        <div><strong>Physics problem:</strong> ${fmtValue(selectedCase?.physics_problem ?? metadata.physics_problem)}</div>
        <div><strong>Cluster:</strong> ${fmtValue(selectedCase?.cluster_name ?? metadata.cluster_name)}</div>
        <div><strong>Test case:</strong> ${fmtValue(metadata.test_case_identifier || metadata.testcase)}</div>
        <div><strong>Language:</strong> ${fmtValue(metadata.language)}</div>
        <div><strong>Commit:</strong> ${fmtValue(metadata.commit_short || metadata.commit)}</div>
        <div><strong>Pyccel:</strong> ${fmtValue(
          [metadata.pyccel_language, metadata.pyccel_compiler_family].filter(Boolean).join(" / "),
        )}</div>
      </div>
      <p class="muted" style="white-space: pre-wrap; margin-bottom: 0;">
        ${esc(selectedCase?.description ?? metadata.test_case_description ?? "")}
      </p>
    `;
  };

  const render = async () => {
    try {
      const requestedCase = new URLSearchParams(window.location.search).get("case");
      const res = await fetch(`${baseUrl}figures/region_statistics.json`);
      if (!res.ok) throw new Error(`HTTP ${res.status}`);
      const data = await res.json();
      const allFiles = Array.isArray(data.files) ? data.files.slice() : [];
      const cases = Array.isArray(data.cases) ? data.cases.slice() : [];

      if (!allFiles.length || !cases.length) {
        casePanel.innerHTML = "<p class='muted'>No cases found in region_statistics.json.</p>";
        return;
      }

      const selectedCase =
        cases.find((entry) => entry.id === requestedCase) ??
        cases.find((entry) =>
          allFiles.some((file) => file.case_id === entry.id && file.label === requestedCase),
        ) ??
        cases[0];

      const files = allFiles
        .filter((entry) => entry.case_id === selectedCase.id)
        .sort((a, b) => (a.num_ranks ?? Number.MAX_SAFE_INTEGER) - (b.num_ranks ?? Number.MAX_SAFE_INTEGER));
      const commonRegions = Array.isArray(selectedCase.common_regions)
        ? selectedCase.common_regions
        : [];

      if (!files.length) {
        casePanel.innerHTML = "<p class='muted'>No runs found for the selected case.</p>";
        renderPlots(selectedCase);
        renderCaseMetadata(selectedCase);
        return;
      }

      const selectedIndex = Math.max(
        0,
        files.findIndex((entry) => entry.label === requestedCase),
      );

      renderPlots(selectedCase);
      renderCaseMetadata(selectedCase);
      let activeRow = null;
      files.forEach((entry, index) => {
        const row = document.createElement("tr");
        row.className = `case-row${index === selectedIndex ? " active" : ""}`;
        row.tabIndex = 0;
        row.innerHTML = `
          <td><strong>${esc(entry.label ?? "Unnamed run")}</strong></td>
          <td>${entry.num_ranks ?? "-"}</td>
          <td>${Object.keys(entry.region_statistics || {}).length}</td>
          <td><a href="${baseUrl}run?case=${encodeURIComponent(selectedCase.id)}&run=${encodeURIComponent(entry.label ?? "")}">Run details</a></td>
        `;

        const select = () => {
          if (activeRow) activeRow.classList.remove("active");
          row.classList.add("active");
          activeRow = row;
          renderCase(entry, commonRegions);
        };

        row.addEventListener("click", select);
        row.addEventListener("keydown", (event) => {
          if (event.key === "Enter" || event.key === " ") {
            event.preventDefault();
            select();
          }
        });

        casesTableBody.appendChild(row);
      });

      renderCase(files[selectedIndex], commonRegions);
      activeRow = casesTableBody.querySelector(".case-row.active");
    } catch (error) {
      casePanel.innerHTML = `<p class='muted'>Could not load metadata: ${error}</p>`;
    }
  };

  render();
</script>
